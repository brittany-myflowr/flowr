{
  "expo": {
    "name": "flowr",
    "slug": "flowr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-store-icon.png",
    "userInterfaceStyle": "light",
    "scheme": ["flowr", "com.brittanytheodore.flowr"],
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": "./assets/app-store-icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.brittanytheodore.flowr",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "flowr",
              "com.brittanytheodore.flowr",
              "com.googleusercontent.apps.414750833272-8vctbeuvhlrtej005t1n2vgu50kj8nre"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.brittanytheodore.flowr",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.414750833272-8vctbeuvhlrtej005t1n2vgu50kj8nre"
        }
      ],
      "./plugins/withGoogleModularHeaders"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "372e4f9e-05d1-4361-8835-5504659a5471"
      }
    }
  }
}
